{
  "name": "daily-report-generator",
  "version": "1.0.0",
  "description": "石油钻井日报快速生成工具",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:all": "electron-builder --win --mac --linux"
  },
  "author": "瓶子 <pzxsky@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.bottle.dailyreport",
    "productName": "钻井日报生成器",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "config.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
